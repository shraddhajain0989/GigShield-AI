{
  "name": "gigshield-ai-server",
  "version": "1.0.0",
  "description": "GigShield AI — Backend API Server for Parametric Insurance Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node src/config/migrate.js",
    "seed": "node src/config/seed.js",
    "trigger-engine": "node src/services/trigger-engine/runner.js",
    "setup": "npm run migrate && npm run seed",
