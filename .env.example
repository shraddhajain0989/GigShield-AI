# ============================================================================
# GigShield AI — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── Application ──
NODE_ENV=development
PORT=5000

# ── Database (PostgreSQL) ──
# Local: postgresql://gigshield:password@localhost:5432/gigshield
# Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://gigshield:gigshield_dev_2026@localhost:5432/gigshield
DB_USER=gigshield
DB_PASSWORD=gigshield_dev_2026

# ── Redis ──
# Local: redis://localhost:6379
# Upstash: rediss://default:[password]@[endpoint].upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Authentication ──
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ── External APIs ──
WEATHER_API_KEY=your_openweathermap_api_key
AQI_API_KEY=your_waqi_api_key
GOOGLE_MAPS_KEY=your_google_maps_key

# ── AI Microservices ──
PREMIUM_API_URL=http://localhost:8001
FRAUD_API_URL=http://localhost:8002

# ── Razorpay (Sandbox) ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Frontend ──
VITE_API_URL=http://localhost:5000/api/v1
